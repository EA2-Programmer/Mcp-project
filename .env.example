# ============================================================================
# TrakSYS MCP Server - Environment Configuration
# ============================================================================
# INSTRUCTIONS:
# 1. Copy this file to .env
# 2. Fill in your actual values
# 3. NEVER commit .env to Git!
# ============================================================================

# -----------------------------------------------------------------------------
# Database Connection (REQUIRED)
# -----------------------------------------------------------------------------
# Replace with YOUR database credentials
MSSQL_CONNECTION_STRING="Driver={ODBC Driver 17 for SQL Server};Server=localhost,1433;Database=EBR_Template;UID=mcp_user;PWD=YOUR_PASSWORD_HERE"

# -----------------------------------------------------------------------------
# Security Settings
# -----------------------------------------------------------------------------
# Keep READ_ONLY=true unless you're specifically testing write operations
READ_ONLY=true

# Only set to true if you need to test write operations
ENABLE_WRITES=false

# -----------------------------------------------------------------------------
# Server Configuration
# -----------------------------------------------------------------------------
# Transport mode: stdio (for development) or http (for OpenWebUI demo)
SERVER_TRANSPORT=stdio

# HTTP settings (NOT NEEDED FOR NOW TILL WE USING WEB)
HTTP_BIND_HOST=0.0.0.0
HTTP_BIND_PORT=8080

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_FORMAT=text

# -----------------------------------------------------------------------------
# Query Limits
# -----------------------------------------------------------------------------
MAX_ROWS=1000
MSSQL_QUERY_TIMEOUT=30